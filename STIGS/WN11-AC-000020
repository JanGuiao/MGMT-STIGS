# STIG WN11-AC-000020 - Enforce Password History (>= 24)
$requiredHistory = 24

Write-Host "Setting Enforce Password History to $requiredHistory..." -ForegroundColor Cyan

# Apply setting
net accounts /uniquepw:$requiredHistory | Out-Null

# Verify setting
$policy = net accounts | Select-String "Length of password history maintained"

if ($policy -match "\d+") {
    $current = [int]($matches[0])

    if ($current -ge $requiredHistory) {
        Write-Host "PASS: Password history is set to $current" -ForegroundColor Green
    } else {
        Write-Host "FAIL: Password history is $current (expected $requiredHistory)" -ForegroundColor Red
    }
} else {
    Write-Host "Unable to verify password history setting." -ForegroundColor Yellow
}
